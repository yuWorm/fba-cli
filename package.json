{
  "name": "@yuworm/fba-cli",
  "version": "0.1.1",
  "description": "CLI tool for creating, managing, and running fastapi-best-architecture projects",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/yuWorm/fba-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yuWorm/fba-cli.git"
  },
  "bugs": {
    "url": "https://github.com/yuWorm/fba-cli/issues"
  },
  "bin": {
    "fba-cli": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "README_en.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build ./src/index.ts --target node --outdir ./dist --format esm --splitting",
    "typecheck": "bunx tsc --noEmit",
    "prepublishOnly": "bun run typecheck && bun run build"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@clack/core": "^1.1.0",
    "@clack/prompts": "^1.1.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "ofetch": "^1.5.1",
    "picocolors": "^1.1.1",
    "smol-toml": "^1.6.0"
  }
}
